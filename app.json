{
  "expo": {
    "name": "Nerdie Blaq Fit",
    "slug": "nerdie-blaq-fit",
    "scheme": "nerdieblaqfit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "jsEngine": "hermes",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.rootcee.nerdieblaq.fit",
      "buildNumber": "4",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090B"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8de17c7-a488-4178-a10d-e25eabaeb78c"
      }
    },
    "owner": "rootcee"
  }
}
